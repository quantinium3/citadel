server {
    listen 80;
    server_name {{ item.subdomain }}.{{ nginx_base_domain }};

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name {{ item.subdomain }}.{{ nginx_base_domain }};

    ssl_certificate /etc/nginx/certs/{{ item.subdomain }}.{{ nginx_base_domain }}.pem;
    ssl_certificate_key /etc/nginx/certs/{{ item.subdomain }}.{{ nginx_base_domain }}.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_stapling on;
    ssl_stapling_verify on;

    {% for container in item.containers %}
    location {{ container.path }} {
        proxy_pass http://127.0.0.1:{{ container.host_port }};

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    {% endfor %}

    access_log /var/log/nginx/{{ item.subdomain }}.access.log;
    error_log /var/log/nginx/{{ item.subdomain }}.error.log;
}
